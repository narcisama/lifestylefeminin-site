---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Pagina negasita">
  <div class="not-found glass-card">
    <h1 class="gradient-text">404</h1>
    <p>Pagina cautata nu exista.</p>
    <a href="/" class="home-link">Inapoi la prima pagina</a>
  </div>
</BaseLayout>

<style>
  .not-found { text-align: center; padding: 40px 20px; }
  h1 { font-size: 4rem; font-weight: 800; margin-bottom: 20px; }
  p { margin-bottom: 30px; }
  .home-link {
    display: inline-block;
    padding: 12px 24px;
    background: linear-gradient(135deg, #ff0080, #ff1493);
    color: white;
    text-decoration: none;
    border-radius: 12px;
    font-weight: 700;
  }
</style>
