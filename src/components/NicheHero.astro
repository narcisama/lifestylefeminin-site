---
interface Props {
  title: string;
  tagline: string;
  imagePath: string;
  imageAlt: string;
}

const { title, tagline, imagePath, imageAlt } = Astro.props;
---

<section class="niche-hero glass-card">
  <div class="niche-hero-image">
    <img
      src={imagePath}
      alt={imageAlt}
      loading="eager"
      decoding="async"
      width="800"
      height="450"
    />
  </div>
  <div class="niche-hero-content">
    <h1 class="niche-hero-title gradient-text">{title}</h1>
    <p class="niche-hero-tagline">{tagline}</p>
  </div>
</section>

<style>
  .niche-hero {
    padding: 0;
    overflow: hidden;
    margin-bottom: 20px;
  }
  .niche-hero-image {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #1a0a2e;
  }
  .niche-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .niche-hero-content {
    padding: 20px;
    text-align: center;
  }
  .niche-hero-title {
    font-size: 1.6rem;
    font-weight: 800;
    margin-bottom: 8px;
    line-height: 1.2;
  }
  .niche-hero-tagline {
    font-size: 0.9rem;
    color: rgba(240, 230, 255, 0.8);
    line-height: 1.5;
  }
</style>
