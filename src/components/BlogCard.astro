---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, publishDate, image, imageAlt, niche } = post.data;
const url = `/blog/${post.slug}/`;
---

<article class="blog-card glass-card">
  <a href={url} class="blog-card-link">
    <div class="blog-card-image">
      <img src={image} alt={imageAlt} loading="lazy" width="400" height="225" />
    </div>
    <div class="blog-card-content">
      <span class="blog-card-niche">{niche}</span>
      <h2 class="blog-card-title">{title}</h2>
      <p class="blog-card-description">{description}</p>
      <time class="blog-card-date" datetime={publishDate.toISOString()}>
        {publishDate.toLocaleDateString('ro-RO', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        })}
      </time>
    </div>
  </a>
</article>

<style>
  .blog-card {
    padding: 0;
    overflow: hidden;
    margin-bottom: 16px;
    transition: transform 0.3s ease;
  }
  .blog-card:hover { transform: translateY(-4px); }
  .blog-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .blog-card-image {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #1a0a2e;
  }
  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .blog-card-content { padding: 16px; }
  .blog-card-niche {
    display: inline-block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #ff6eb4;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .blog-card-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 8px;
    color: #fff;
    line-height: 1.3;
  }
  .blog-card-description {
    font-size: 0.85rem;
    color: rgba(240, 230, 255, 0.75);
    line-height: 1.5;
    margin-bottom: 12px;
  }
  .blog-card-date {
    font-size: 0.75rem;
    color: rgba(240, 230, 255, 0.5);
  }
</style>
