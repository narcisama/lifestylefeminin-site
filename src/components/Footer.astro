---
import { SITE_CONFIG } from '../config/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p>&copy; {year} {SITE_CONFIG.name}. Toate drepturile rezervate.</p>
  <p class="partner">
    Profil oficial:
    <a href={SITE_CONFIG.partners.sonia11.url} target="_blank" rel="noopener">
      {SITE_CONFIG.partners.sonia11.url}
    </a>
  </p>
</footer>

<style>
  .site-footer {
    margin-top: 32px;
    padding: 18px 0;
    text-align: center;
    font-size: 0.75rem;
    color: rgba(240, 230, 255, 0.55);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .partner a {
    color: #ff6eb4;
    text-decoration: none;
    border-bottom: 1px dashed #ff6eb4;
  }
</style>
