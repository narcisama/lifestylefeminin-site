---
import { SITE_CONFIG } from '../config/site';
---

<header class="site-header">
  <a href="/" class="logo">{SITE_CONFIG.name}</a>
  <nav>
    <a href="/">Acasa</a>
    <a href="/despre/">Despre</a>
  </nav>
</header>

<style>
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    margin-bottom: 16px;
  }
  .logo {
    font-weight: 800;
    text-decoration: none;
    color: #ff6eb4;
    font-size: 1rem;
  }
  nav a {
    color: rgba(240, 230, 255, 0.8);
    text-decoration: none;
    margin-left: 14px;
    font-size: 0.85rem;
  }
  nav a:hover { color: #ff6eb4; }
</style>
